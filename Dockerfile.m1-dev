# =============================================================================
# Aetheris UI M1 - WASM Ligero Development Environment
# Incluye Python, Node.js, Rust y Ollama para desarrollo de M1
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Builder - Instalar dependencias Python
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /build

COPY requirements.txt .
RUN pip install --prefix=/install -r requirements.txt

# ---------------------------------------------------------------------------
# Stage 2: Base - Python + Node.js + Rust
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Node.js 20.17.0 (LTS,-released 2025-01)
# Instalar como root para evitar problemas de permisos
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gnupg \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com node_20.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Rust (stable)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"

# ---------------------------------------------------------------------------
# Stage 3: Ollama (instalación manual para control de versiones)
# ---------------------------------------------------------------------------
FROM base AS ollama-stage

ENV OLLAMA_VERSION=0.5.2

RUN curl -fsSL "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-amd64" -o /usr/local/bin/ollama \
    && chmod +x /usr/local/bin/ollama \
    && ollama --version

# ---------------------------------------------------------------------------
# Stage 4: Runtime - Imagen final de desarrollo
# ---------------------------------------------------------------------------
FROM ollama-stage AS runtime

# Dependencias del sistema
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1-mesa-dri \
    libgl1 \
    libegl1 \
    libgles2 \
    xvfb \
    git \
    vim \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copiar Python packages del builder
COPY --from=builder /install /usr/local

# Copiar proyecto
WORKDIR /app
COPY . .

# Descargar modelo Ollama (llama3.2:1b)
# Esto se hace en runtime para reducir tamaño del contenedor
ENV OLLAMA_HOST=127.0.0.1:11434
RUN ollama pull llama3.2:1b || true

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python3 -c "from core.engine import AetherEngine; print('OK')" || exit 1

# Puerto para desarrollo
EXPOSE 5173 8000 11434

CMD ["python3", "-m", "pytest", "tests/", "-v", "-m", "core"]